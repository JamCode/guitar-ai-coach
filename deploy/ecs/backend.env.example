BACKEND_HOST=127.0.0.1
BACKEND_PORT=18080
# Optional: backend logging
# BACKEND_LOG_LEVEL=INFO
# BACKEND_LOG_DIR=../logs

# Optional: DashScope settings
# DASHSCOPE_API_KEY=your_api_key
# DASHSCOPE_MODEL=qwen3.5-flash
# DASHSCOPE_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# Optional: MySQL settings（配置后和弦 explain 会先读库缓存，未命中再调大模型并写入）
# 须先在库中执行建表：backend/database/ddl/chord_explain_cache.sql
# 表权限示例：backend/database/ddl/grant_chord_explain_cache_guitar_app.sql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=guitar_app
# MYSQL_PASSWORD=your_guitar_app_password
# MYSQL_DATABASE=guitar_ai_coach
