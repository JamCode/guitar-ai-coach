# 复制为 upload-testflight.local.env 后填写（该文件已在 .gitignore 中忽略）
# Team ID：Xcode -> Settings -> Accounts -> Team 名称后括号中的 10 位字符
export DEVELOPMENT_TEAM=7R8RS88G2M

# App Store Connect API Key 信息（Users and Access -> Keys）
export ASC_KEY_ID=YOUR_KEY_ID
export ASC_ISSUER_ID=YOUR_ISSUER_ID

# AuthKey_<KEY_ID>.p8 的本机绝对路径（不要放仓库内）
export ASC_KEY_PATH="$HOME/Documents/certs/AuthKey_YOUR_KEY_ID.p8"
